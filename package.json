{
  "name": "ikonoijoy-sorter",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://alief-alwan.github.io/ikonoijoy-sorter",
  "dependencies": {
    "html2canvas": "^1.4.1",
    "kuromoji": "^0.1.2",
    "path-browserify": "^1.0.1",
    "react": "^18.2.0",
    "react-app-rewired": "^2.2.1",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "wanakana": "^5.3.1"
  },
  "scripts": {
    "prestart": "node -e \"require('fs').cpSync('node_modules/kuromoji/dict','public/dict',{recursive:true})\"",
    "start": "react-app-rewired start",
    "prebuild": "node -e \"require('fs').cpSync('node_modules/kuromoji/dict','public/dict',{recursive:true})\"",
    "build": "react-app-rewired build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
